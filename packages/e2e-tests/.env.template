# =============================================================================
# Veltro Novo E2E — Playwright environment configuration
# =============================================================================
#
# HOW TO USE:
#   1. Copy this file to .env in the same directory.
#   2. Replace <PLACEHOLDER> values where indicated.
#   3. NEVER commit .env — it's in .gitignore.
#   4. Run .\auth-veltro.ps1 from the repo root to cache storage state.
# =============================================================================

# ----- Power Apps / Maker Portal -----
POWER_APPS_BASE_URL=https://make.powerapps.com

# Veltro Env Dev — confirmed in veltro-novo/CLAUDE.md
POWER_APPS_ENVIRONMENT_ID=31526b49-62a2-e0ac-84b7-c5b854521b49

# ----- Veltro Novo Code App -----
# Live Code App URL (from veltro-novo/docs/session-handoffs/*).
# Format: https://apps.powerapps.com/play/e/<env-id>/app/<app-id>
CODE_APP_URL=https://apps.powerapps.com/play/e/31526b49-62a2-e0ac-84b7-c5b854521b49/app/801a1353-ed03-4c01-b215-c05c217eaf97
CODE_APP_ID=801a1353-ed03-4c01-b215-c05c217eaf97
CODE_APP_TENANT_ID=ce3d0b22-c905-4093-8a06-3d2c61420d9b

# Dataverse Web API base (used by helpers, not by the Code App itself)
DATAVERSE_BASE_URL=https://veltro.crm4.dynamics.com

# ----- Auth — interactive user (e2e-veltro@) -----
# The password is NEVER set here. It's injected at runtime by auth-veltro.ps1
# via the MS_USER_PASSWORD env variable.

MS_AUTH_EMAIL=<PLACEHOLDER: replace with e2e-veltro@powerfoxbi.com or whichever account you provisioned>
MS_AUTH_CREDENTIAL_TYPE=password
MS_AUTH_CREDENTIAL_PROVIDER=environment
MS_AUTH_ENV_VARIABLE_NAME=MS_USER_PASSWORD
MS_AUTH_HEADLESS=false
MS_AUTH_WAIT_FOR_MSAL_TOKENS=true
MS_AUTH_MSAL_TOKEN_TIMEOUT=120000
MS_AUTH_STORAGE_STATE_EXPIRATION=24
AUTH_ENDPOINT=https://login.microsoftonline.com

# ----- Playwright test runner -----
HEADLESS=false
WORKERS=1
TEST_TIMEOUT=120000
SLOW_MO=0
OUTPUT_DIRECTORY=./test-results
