# =============================================================================
# Power Platform E2E Tests — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it contains credentials.
# =============================================================================

# =============================================================================
# Power Apps / Maker Portal
# =============================================================================

# Base URL of the Maker Portal (default: https://make.powerapps.com)
# Use the preview URL to test pre-release features
POWER_APPS_BASE_URL=https://make.powerapps.com

# Environment GUID — used for direct /environments/:id/apps navigation
# Find it in the Maker Portal URL: make.powerapps.com/environments/<GUID>/...
POWER_APPS_ENVIRONMENT_ID=Default-00000000-0000-0000-0000-000000000000

# Gen UX / Maker Portal URL override (optional)
# Set this if you want to test against the preview portal
# MAKER_PORTAL_URL=https://make.preview.powerapps.com

# =============================================================================
# Model-Driven App
# =============================================================================

# Full URL of the Model-Driven App (required for MDA tests)
# How to find: Open your MDA in the browser and copy the URL including ?appid=
MODEL_DRIVEN_APP_URL=https://your-org.crm.dynamics.com/main.aspx?appid=00000000-0000-0000-0000-000000000000

# =============================================================================
# Canvas App
# =============================================================================

# Option A: Component IDs (recommended — toolkit builds the play URL automatically)
# App ID: Open app in Maker Portal → Details → App ID
CANVAS_APP_ID=00000000-0000-0000-0000-000000000000
# Tenant ID: Azure Portal → Azure Active Directory → Overview → Tenant ID
CANVAS_APP_TENANT_ID=00000000-0000-0000-0000-000000000000

# Option B: Full play URL (takes precedence over IDs above if set)
# How to find: Open app in Maker Portal → Play → copy URL from browser
# CANVAS_APP_URL=https://apps.powerapps.com/play/e/<env-id>/a/<app-id>?tenantId=<tenant-id>

# =============================================================================
# Microsoft Authentication (playwright-ms-auth)
# =============================================================================

# Account email — used to derive the storage state file path
MS_AUTH_EMAIL=user@contoso.com

# --- Password authentication ---
MS_AUTH_CREDENTIAL_TYPE=password
MS_AUTH_CREDENTIAL_PROVIDER=environment
MS_AUTH_ENV_VARIABLE_NAME=MS_USER_PASSWORD
MS_USER_PASSWORD=your-password-here

# --- Certificate authentication (recommended for CI/CD) ---
# MS_AUTH_CREDENTIAL_TYPE=certificate
# MS_AUTH_CREDENTIAL_PROVIDER=local-file
# MS_AUTH_LOCAL_FILE_PATH=./cert/your-cert.pfx
# MS_AUTH_CERTIFICATE_PASSWORD=your-cert-password

# Run authentication browser in headed mode (set to false for CI)
MS_AUTH_HEADLESS=true

# Wait for MSAL tokens to appear in localStorage before saving state
MS_AUTH_WAIT_FOR_MSAL_TOKENS=true
MS_AUTH_MSAL_TOKEN_TIMEOUT=30000

# Hours before a saved storage state file is considered stale and deleted (default: 24)
# Increase if your browser session cookies outlive this window; decrease for tighter security.
MS_AUTH_STORAGE_STATE_EXPIRATION=24

# Authentication endpoint (default: https://login.microsoftonline.com)
AUTH_ENDPOINT=https://login.microsoftonline.com

# =============================================================================
# Test Runner Configuration
# =============================================================================

# Run browser in headless mode (true/false). Overridden to true in CI.
HEADLESS=true

# Number of parallel workers. Overridden to 1 in CI.
WORKERS=1

# Number of retries on failure. Overridden to 1 in CI.
RETRIES=0

# Test timeout in milliseconds
TEST_TIMEOUT=120000

# Slow-motion delay between actions in milliseconds (0 = off)
SLOW_MO=0

# Output directory for test results, reports, and artifacts
OUTPUT_DIRECTORY=./test-results

# Grep filter — only run tests matching this regex (optional)
# GREP=@smoke
