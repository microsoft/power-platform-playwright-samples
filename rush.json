{
  "rushVersion": "5.175.1",

  "pnpmVersion": "10.33.4",

  "nodeSupportedVersionRange": ">=20.12.1 <21.0.0",

  "ensureConsistentVersions": true,

  "gitPolicy": {
    "allowedEmailRegExps": [".*"],
    "sampleEmail": "deepak.kamboj@microsoft.com",

    "changeLogUpdateCommitMessage": "Update Change Logs [skip ci]",
    "versionBumpCommitMessage": "Apply Package Updates [skip ci]"
  },

  "repository": {
    "url": "https://github.com/microsoft/power-platform-playwright-samples.git",
    "defaultBranch": "main",
    "defaultRemote": "origin"
  },

  "eventHooks": {
    "preRushInstall": [],
    "postRushInstall": [],
    "preRushBuild": [],
    "postRushBuild": []
  },

  "telemetryEnabled": true,

  "projects": [
    {
      "packageName": "power-platform-playwright-toolkit",
      "projectFolder": "packages/power-platform-playwright-toolkit",
      "shouldPublish": true
    },
    {
      "packageName": "@power-platform-playwright/e2e-tests",
      "projectFolder": "packages/e2e-tests",
      "shouldPublish": false
    }
  ]
}
